---
import BaseLayout from '../layouts/BaseLayout.astro';

const differItems = [
  {
    num: 'I.',
    title: 'Research-Backed Insights',
    sub: 'Investment and portfolio insights powered by comprehensive market research',
    points: [
      'Access high-conviction, SEBI-registered technical and fundamental research to capture sharp market movements.',
      'Trade and invest with confidence using deep-dive macroeconomic reports and real-time data analytics.',
    ],
    cta: 'Explore Research',
    href: '/research/',
  },
  {
    num: 'II.',
    title: 'A Relationship-Led Human Experience',
    sub: 'Premium investing experience with dedicated relationship management',
    points: [
      'Get mapped with experienced domain experts who understand your risk appetite and financial milestones.',
      'Experience seamless, personalized portfolio reviews over a call or in person, moving past automated chatbots.',
    ],
    cta: 'Meet Your Advisor',
    href: '/about/',
  },
  {
    num: 'III.',
    title: 'Partner Network',
    sub: 'Access to a dense nationwide network of trusted partners',
    points: [
      'Leverage trusted collaborations with leading financial institutions, asset managers, and tech platforms.',
      'Gain premium access to structured products, unique PMS strategies, and highly curated investment avenues.',
    ],
    cta: 'Our Story',
    href: '/about/',
  },
  {
    num: 'IV.',
    title: 'Personalized Notifications',
    sub: 'Personalized nudges for critical actionables and market opportunities',
    points: [
      'Receive instant, actionable alerts tailored to your active watchlist, technical breakouts, and entry/exit zones.',
      'Stay updated with automated, relevant news and rebalancing alerts without information overload.',
    ],
    cta: 'Explore Antara',
    href: '/about/antara-web-login/',
  },
];

const advisoryCards = [
  {
    img: '/advisory/icon-1.png',
    title: 'Expert Research Calls',
    body: 'Daily SEBI-registered market research and insights.',
    cta: 'Start Learning',
    href: '/research/',
  },
  {
    img: '/advisory/icon-2.png',
    title: 'Trade Indian Equities',
    body: 'Access & execute seamless trades across the NSE and BSE.',
    cta: 'Explore Market',
    href: '/products/equity/',
  },
  {
    img: '/advisory/icon-3.png',
    title: "Today's Trading Ideas",
    body: 'Learn proven techniques from seasoned traders.',
    cta: 'Discover Trading Ideas',
    href: '/research/technical/',
  },
  {
    img: '/advisory/icon-4.png',
    title: 'Get Expert Advice',
    body: 'Stay aware and informed with real-time market analysis.',
    cta: 'Connect With An Advisor',
    href: '/about/support/',
  },
];

const allProducts = [
  { label: 'Stocks',                        href: '/products/equity/',        sub: 'Trade in NSE & BSE Equity with zero-delay and in-depth research support.',              img: '/products/icon-equity.svg' },
  { label: 'Margin Trading Facility (MTF)', href: '/products/mtf/',           sub: 'Trade with leverage and increase your buying power with flexible margin options.',       img: '/products/icon-mtf.svg' },
  { label: 'Derivatives',                   href: '/products/derivative/',    sub: 'Trade Futures & Options to hedge your portfolio or maximise returns.',                   img: '/products/icon-derivatives.svg' },
  { label: 'Mutual Funds',                  href: '/products/mutual-funds/',  sub: 'Compare 3,000+ Funds across categories and invest in direct plans at zero commission.', img: '/products/icon-mf.svg' },
  { label: 'Loan Against Mutual Funds (LAMF)', href: '/products/mtf/',        sub: 'Get instant loans against your mutual fund holdings at competitive interest rates.',    img: '/products/icon-lamf.svg' },
  { label: 'Initial Public Offering (IPO)', href: '/products/ipo/',           sub: 'Apply for upcoming IPOs seamlessly. Explore GMP & Allotment News.',                     img: '/products/icon-ipo.svg' },
  { label: 'Exchange Traded Funds (ETF)',    href: '/products/etf/',           sub: 'Diversify your portfolio with ETFs tracking indices, sectors, and commodities.',        img: '/products/icon-etf.svg' },
  { label: 'National Pension Scheme (NPS)', href: '/products/nps/',           sub: 'Tailored strategies for high-net-worth investors by SEBI-registered experts.',          img: '/products/icon-nps.svg' },
];

const faqs = [
  {
    q: 'What is a Demat Account?',
    a: 'A Demat (Dematerialised) account holds your shares, bonds, mutual funds, and ETFs in electronic form — eliminating physical certificates. It is mandatory for trading on Indian stock exchanges (NSE and BSE). With Shriram, opening a Demat account is 100% digital and takes under 10 minutes.',
  },
  {
    q: 'What are the benefits of a Demat Account?',
    a: 'A Demat account eliminates risks associated with physical certificates (theft, forgery, damage). You get instant transfer of securities, easy monitoring of all holdings in one place, automatic credit of bonuses and splits, and seamless participation in IPOs, buybacks, and rights issues.',
  },
  {
    q: 'What are the brokerage charges for options trading with Shriram Securities?',
    a: 'Brokerage charges for options trading are structured to be competitive and straightforward. Shriram Securities charges a flat fee of ₹20 per executed order for options trading. To further understand and calculate the total costs, including brokerage, taxes, and other fees, you can use the Brokerage Calculator. This tool helps you estimate the net profit or loss on your trades by accounting for all applicable charges.',
  },
  {
    q: 'Are there any charges associated with the Demat Account?',
    a: 'Account opening and Annual Maintenance Charges (AMC) are ₹0 for both Trading and Demat Accounts. Standard SEBI and exchange-mandated statutory charges (STT, exchange transaction charges, GST, SEBI fees) apply to all trades as per regulations.',
  },
  {
    q: 'What is Intraday brokerage and Option brokerage?',
    a: 'Intraday equity trades are charged at a flat ₹20 per executed order. Options trades are also charged at a flat ₹20 per executed order, regardless of the premium value or lot size. Equity delivery is ₹0 — no brokerage.',
  },
  {
    q: 'Can I have multiple Demat Accounts?',
    a: 'Yes, SEBI permits investors to hold multiple Demat accounts across different depository participants (DPs). However, each account has its own AMC and charges. With Shriram, your Demat account is linked to your Trading account on the Antara platform for seamless management.',
  },
  {
    q: 'Is a Demat Account mandatory for applying for an IPO?',
    a: 'Yes. SEBI mandates that all IPO applications — whether through UPI ASBA or net banking — require a valid Demat account for share allotment. If allotted, shares are credited directly to your Demat account within T+6 days of the IPO closing date.',
  },
];
---

<BaseLayout title="" description="Shriram Financial Services — Advisory-Led Wealth Curation. Invest across equity, mutual funds, bonds and more with India's most trusted platform.">

  <!-- ══ HERO ══ -->
  <section class="relative xl:min-h-[calc(100vh-80px)] overflow-hidden">
    <div class="hero-wave" aria-hidden="true"></div>
    <video id="hero-video"
      class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-1000"
      autoplay muted playsinline aria-hidden="true">
      <source src="/BG.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-r from-white/82 via-white/48 to-white/0" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-black/8 via-transparent to-black/12" aria-hidden="true"></div>

    <div class="site-wrap relative z-10 flex items-start gap-8 py-14 sm:py-20 lg:py-24 xl:min-h-[calc(100vh-80px)] xl:items-center xl:gap-12 xl:py-0">

      <!-- Left text -->
      <div class="w-full xl:max-w-[560px] xl:shrink-0 reveal reveal-1">
        <h1 class="text-[28px] font-normal leading-[1.30] text-[#2e3914] sm:text-[36px] lg:text-[54px]" style="font-family:var(--font-display)">
          Beyond Portfolios<br>
          <span class="font-bold text-[var(--color-brand)]">Advisory-Led</span> Wealth Curation
        </h1>
        <p class="mt-5 text-[15px] leading-relaxed text-[#2e3914] lg:text-[17px]">
          Don't just trade; grow your wealth with India's most trusted advisory.
        </p>

        <!-- Trust badges -->
        <div class="mt-5 flex flex-wrap items-center gap-x-3 gap-y-1.5">
          {['Trusted By 10L+ Investors', 'In-House Analyst Team', 'Pan-India Presence'].map((t, i) => (
            <div class="flex items-center gap-3">
              {i > 0 && <span class="trust-dot"></span>}
              <span class="text-[14px] font-medium text-[#2e3914]">{t}</span>
            </div>
          ))}
        </div>

        <div class="mt-8">
          <a href="/about/antara-web-login/" class="inline-flex items-center justify-center gap-1.5 h-[48px] px-6 rounded-[4px] bg-[#2e3914] text-white text-[14px] font-medium hover:bg-[#1a2010] transition-colors" style="width:220px">Explore Antara</a>
        </div>
      </div>

      <!-- Right: glass Open Demat card -->
      <div class="reveal reveal-2 hidden flex-1 justify-end xl:flex xl:pr-[4%]">
        <div class="warm-form w-full max-w-[520px] p-[56px]">

          <!-- Title + badges (gap-[16px] per Figma) -->
          <div class="flex flex-col gap-4">
            <h2 class="text-[32px] font-medium leading-tight text-[#4f583b]">
              Open a Demat Account
            </h2>
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5">
              {['100% Paperless', 'Open Within Minutes', 'SEBI Regulated'].map((t, i) => (
                <div class="flex items-center gap-3">
                  {i > 0 && <span class="trust-dot"></span>}
                  <span class="text-[12px] font-medium text-[#4f583b]">{t}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Form fields (gap-[48px] from title block, gap-[24px] between fields) -->
          <div class="mt-12 flex flex-col gap-6">
            <!-- Mobile input -->
            <div class="flex h-[48px] items-center rounded-[8px] border border-[var(--color-n500)] bg-white px-4">
              <span class="shrink-0 text-[13px] font-semibold text-[var(--color-n900)]">IN</span>
              <span class="mx-3 h-5 w-px shrink-0 bg-[var(--color-n400)]"></span>
              <span class="shrink-0 text-[13px] font-medium text-[var(--color-n800)]">+91</span>
              <span class="mx-3 h-5 w-px shrink-0 bg-[var(--color-n400)]"></span>
              <input
                type="tel"
                placeholder="Enter mobile number"
                class="min-w-0 flex-1 border-none bg-transparent text-[14px] text-[var(--color-ink)] outline-none placeholder:text-[var(--color-n500)]"
              />
            </div>

            <!-- Consent text -->
            <p class="text-[12px] leading-relaxed text-[var(--color-n700)]">
              By continuing, I agree to receive the OTP and updates via SMS/WhatsApp.
            </p>

            <!-- Buttons (gap-[16px]) -->
            <div class="flex flex-col gap-4">
              <a href="/about/open-demat-account/" class="inline-flex h-[48px] w-full items-center justify-center rounded-[4px] bg-[#f3b83f] text-[14px] font-medium text-[#202318] transition-colors hover:bg-[#d4982a]">
                Get Started
              </a>
              <p class="text-center text-[12px] text-[var(--color-n900)]">
                Already a part of us?{' '}
                <a href="/about/antara-web-login/" class="font-bold text-[#f3b83f] hover:underline">Login Here.</a>
              </p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>

  <!-- ══ HOW ARE WE DIFFERENT? ══ -->
  <section class="bg-white py-8">
    <div class="site-wrap">
      <div class="relative overflow-hidden rounded-[24px]" style="background:radial-gradient(ellipse at 40% 50%,#4F583B 0%,#363A2C 45%,#1d1d1d 100%);">
        <!-- subtle warm grid texture -->
        <div class="pointer-events-none absolute inset-0 opacity-[0.04]"
             style="background-image:repeating-linear-gradient(0deg,#e8d090 0,#e8d090 1px,transparent 0,transparent 20px),repeating-linear-gradient(90deg,#e8d090 0,#e8d090 1px,transparent 0,transparent 20px);background-size:20px 20px;"></div>

        <div class="relative z-10 flex flex-col gap-10 p-8 lg:grid lg:grid-cols-[45%_55%] lg:gap-12 lg:p-14">

          <!-- Left: heading + subtitle -->
          <div class="self-center">
            <h2 class="text-[28px] font-bold leading-tight text-white sm:text-[34px] lg:text-[48px]" style="font-family:var(--font-display)">
              How Are We <span class="text-[#f3b83f]">Different?</span>
            </h2>
            <p class="mt-5 text-[15px] leading-relaxed text-[rgba(248,244,232,0.70)]">
              We go beyond execution-only; by fusing together Historical Insights, Human Engagement and Tech that delivers better investing experiences to build long term customer relationships.
            </p>
          </div>

          <!-- Right: scrollable glassmorphism card panel -->
          <div id="differ-scroll" class="flex max-h-[440px] flex-col gap-4 overflow-y-auto pr-2"
               style="scrollbar-width:thin;scrollbar-color:rgba(243,184,63,0.4) transparent;">
            {differItems.map((item) => (
              <div class="rounded-[12px] border-b-2 border-[#f3b83f] p-6"
                   style="background:rgba(116,116,116,0.12);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);">
                <div class="flex items-baseline gap-3">
                  <span class="text-[13px] font-bold text-[rgba(243,184,63,0.60)]">{item.num}</span>
                  <h3 class="text-[19px] font-semibold text-[#f8f4e8]" style="font-family:var(--font-display)">{item.title}</h3>
                </div>
                <p class="mt-1.5 pl-7 text-[13px] text-[rgba(248,244,232,0.60)]">{item.sub}</p>
                <ul class="mt-4 space-y-2 pl-7">
                  {item.points.map(p => (
                    <li class="flex items-start gap-2.5 text-[14px] text-[rgba(248,244,232,0.70)]">
                      <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[#f3b83f]"></span>
                      {p}
                    </li>
                  ))}
                </ul>
                <a href={item.href} class="mt-5 ml-7 inline-flex items-center gap-2 rounded border border-[rgba(243,184,63,0.35)] px-5 py-2.5 text-[13px] font-medium text-[#f8f4e8] transition-colors hover:border-[#f3b83f] hover:bg-[rgba(243,184,63,0.10)]">
                  {item.cta}
                  <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" class="h-3 w-3"><path d="M2 6h8M6 2l4 4-4 4"/></svg>
                </a>
              </div>
            ))}
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ══ STRATEGIC ADVISORY ══ -->
  <section class="bg-white">
    <div class="site-wrap py-16 lg:py-20">
      <h2 class="text-[22px] font-bold text-[var(--color-n900)] sm:text-[28px] lg:text-[42px]" style="font-family:var(--font-display)">
        Strategic Advisory For <span class="text-[var(--color-brand)]">Every Investor</span>
      </h2>
      <p class="mt-4 max-w-4xl text-[15px] text-[var(--color-muted)]">
        From initial concepts to managed portfolios, our personal managers collaborate with you to ensure every transaction is backed by professional insight.
      </p>

      <div class="advisory-grid mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {advisoryCards.map((c) => (
          <div class="advisory-card group relative flex h-[322px] flex-col overflow-hidden rounded-[4px] bg-white px-6 py-10 shadow-[0px_4px_20.5px_-8px_rgba(0,0,0,0.1)]">
            <img src={c.img} alt="" class="h-[80px] w-[100px] shrink-0 object-contain object-left" />
            <div class="mt-8 flex flex-col gap-3">
              <h3 class="text-[16px] font-bold uppercase tracking-[1.2px] text-[var(--color-n900)]">{c.title}</h3>
              <p class="text-[14px] leading-[1.5] text-[var(--color-n800)]">{c.body}</p>
            </div>
            <a href={c.href}
               class="absolute bottom-[-56px] left-0 flex h-14 w-full items-center justify-center gap-3 bg-[var(--color-brand)] text-[14px] font-medium text-[#202318] transition-all duration-300 group-hover:bottom-0">
              {c.cta}
              <img src="/advisory/advisory-icon.svg" alt="" class="h-4 w-4 shrink-0 brightness-0" />
            </a>
          </div>
        ))}
      </div>

      <!-- Nudge CTA -->
      <div class="mt-6 flex flex-col items-center justify-between overflow-hidden rounded-[4px] border border-[var(--color-n400)] bg-white shadow-[0px_8px_30.5px_rgba(0,0,0,0.04)] sm:flex-row">
        <!-- Illustration cropped from Figma nudge component -->
        <div class="hidden h-[170px] w-[220px] shrink-0 items-center justify-center sm:flex">
          <img src="/advisory/nudge-char.png" alt="" class="h-full w-full object-contain" />
        </div>
        <div class="flex flex-1 items-center justify-between gap-6 px-8 py-6">
          <div>
            <p class="text-[18px] font-semibold text-[var(--color-n900)]">
              Unsure on where to begin? <span class="text-[var(--color-brand)]">We've got you.</span>
            </p>
            <p class="mt-2 max-w-xl text-[14px] leading-relaxed text-[var(--color-muted)]">
              Our dedicated specialists evaluate your initial concepts, followed by a personal manager who will collaborate with you to architect a comprehensive financial roadmap.
            </p>
          </div>
          <a href="/about/support/" class="btn-primary shrink-0">Schedule a Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ PRODUCTS ══ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-900)]">
    <div class="pointer-events-none absolute inset-0 opacity-[0.03]"
         style="background-image:repeating-linear-gradient(-45deg,#fff 0,#fff 1px,transparent 0,transparent 50%);background-size:20px 20px;"></div>
    <div class="site-wrap relative py-16 lg:py-20">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2 class="text-[26px] font-bold leading-tight text-white sm:text-[32px] lg:text-[44px]" style="font-family:var(--font-display)">
            Trade, Invest Or Lend. <span class="text-[#f3b83f]">All At One Place.</span>
          </h2>
          <p class="mt-3 text-[15px] text-[rgba(255,255,255,0.55)]">
            From personalized insights to instant transactions, everything you need is now in one place.
          </p>
        </div>
        <a href="/products/" class="shrink-0 text-[13px] font-semibold text-[var(--color-brand-light)] hover:text-white">
          View All Our Products →
        </a>
      </div>
      <div class="mt-10 grid grid-cols-2 gap-4 lg:grid-cols-4" id="products-grid">
        {allProducts.map((p, i) => (
          <a href={p.href}
             class="product-card-reveal group relative flex h-[284px] flex-col overflow-hidden rounded-[24px] border border-white/10 bg-[#2e3914] p-8 hover:z-10 hover:-translate-y-1 hover:scale-[1.02] hover:border-[rgba(243,184,63,0.25)]"
             data-row={i < 4 ? '1' : '2'}
             style={`transition-delay:${(i % 4) * 90}ms`}>
            <!-- Citrus circle grows in top-right corner on hover -->
            <div class="product-card-circle pointer-events-none absolute right-5 top-5">
              <svg viewBox="0 0 24 24" fill="none" stroke="#202318" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 shrink-0">
                <path d="M7 17L17 7M17 7H7M17 7v10"/>
              </svg>
            </div>
            <img src={p.img} alt="" class="h-[44px] w-[44px] shrink-0 object-contain opacity-70 transition-opacity duration-300 group-hover:opacity-100" />
            <div class="mt-auto flex flex-col gap-2">
              <h3 class="text-[15px] font-bold leading-snug text-[#f3b83f]" style="font-family:var(--font-display)">{p.label}</h3>
              <p class="text-[12px] leading-[1.6] text-white/55">{p.sub}</p>
            </div>
            <span class="mt-4 translate-y-1 text-[12px] font-medium text-transparent opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:text-white/60 group-hover:opacity-100">View More</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ HOW SOON CAN I START? ══ -->
  <section class="bg-[#fdfdfd]">
    <div class="site-wrap py-36">

      <!-- Top row: text left + rocket right -->
      <div class="relative flex items-start justify-between gap-12">

        <!-- Left: heading + subtitle + CTA -->
        <div class="flex max-w-[600px] flex-col gap-12">
          <div class="flex flex-col gap-4">
            <h2 class="text-[40px] font-normal leading-[1.4] text-[var(--color-n900)]" style="font-family:var(--font-body)">
              How Soon can I <span class="font-semibold text-[var(--color-brand)]">Start</span>?
            </h2>
            <p class="text-[18px] leading-relaxed tracking-[0.36px] text-[var(--color-n900)]" style="font-family:var(--font-body)">
              Within <strong class="font-bold">minutes</strong>. You can create a Trading Account swiftly in a five-stage online process that can be completed on any of your devices.
            </p>
          </div>
          <a href="/about/open-demat-account/"
             class="flex h-[40px] w-[220px] items-center justify-center rounded-[4px] bg-[var(--color-brand)] text-[12px] font-medium text-[#202318] transition-colors hover:bg-[var(--color-brand-hover)]">
            Open a Demat Account
          </a>
        </div>

        <!-- Right: rocket illustration (725×340) -->
        <div class="hidden flex-1 items-center justify-end lg:flex">
          <img src="/how-soon-rocket.png" alt="Rocket launch illustration"
               width="786" height="655"
               class="w-full max-w-[560px] object-contain"
               style="filter:hue-rotate(180deg) saturate(1.4) brightness(1.05);" />
        </div>
      </div>

      <!-- Steps row — 5 steps connected by a horizontal dashed line -->
      <div class="relative mt-32">
        <div class="absolute left-[24px] right-[24px] top-[32px] border-t border-dashed border-[#e6e6e6]"></div>
        <div class="relative grid grid-cols-2 gap-y-12 sm:grid-cols-5">
          {[
            { img: '/step-1.png', title: 'Basic Information',        desc: 'Name, mobile number, PAN — takes under two minutes.' },
            { img: '/step-2.png', title: 'Complete eKYC via Aadhaar', desc: 'OTP-based verification — no physical forms or branch visits.' },
            { img: '/step-3.png', title: 'Upload Documents',          desc: "Bank proof and a live photograph from your phone's camera." },
            { img: '/step-4.png', title: 'Digital eSign',             desc: 'Aadhaar-based e-sign replaces physical signature on all forms.' },
            { img: '/step-5.png', title: 'Account Activation',        desc: 'Credentials delivered to your registered email. Start investing.' },
          ].map((step) => (
            <div class="flex flex-col items-center gap-6 px-4 text-center">
              <div class="relative z-10 flex h-[64px] w-[48px] shrink-0 items-center justify-center rounded-[8px] border border-[#e6e6e6] bg-white">
                <img src={step.img} alt="" class="h-full w-full object-contain" style="filter:hue-rotate(180deg) saturate(1.4) brightness(1.05);" />
              </div>
              <div class="flex flex-col gap-3">
                <p class="text-[18px] font-medium leading-snug text-[#121212]">{step.title}</p>
                <p class="text-[14px] leading-relaxed text-[#121212] opacity-70">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- ══ MEET ANTARA ══ -->
  <section class="relative overflow-hidden" style="background:radial-gradient(ellipse at top left,#4F583B 0%,#3B4228 25%,#282C1E 50%,#0A0B07 100%);">
    <div class="pointer-events-none absolute -left-48 -top-48 h-[500px] w-[500px] rounded-full bg-[#f3b83f]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-48 right-0 h-[400px] w-[400px] rounded-full bg-[#f3b83f]/8 blur-3xl"></div>
    <div class="site-wrap relative py-16 lg:py-20">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-20">
        <div>
          <p class="text-[11px] font-bold uppercase tracking-widest text-[rgba(255,255,255,0.40)]">Trading Platform</p>
