            <img src="/antara-qr.jpeg" alt="Antara app QR code"
                 class="mx-auto h-52 w-52 object-contain mix-blend-screen"
                 style="filter:invert(1) sepia(0.30) brightness(1.05);" />
            <p class="mt-5 text-[14px] font-medium text-white">Download Now on Android or iOS</p>
