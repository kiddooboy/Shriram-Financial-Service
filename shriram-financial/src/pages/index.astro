---
import BaseLayout from '../layouts/BaseLayout.astro';

const differItems = [
  {
    num: 'I.',
    title: 'Research-Backed Insights',
    sub: 'Investment and portfolio insights powered by comprehensive market research',
    points: [
      'Access high-conviction, SEBI-registered technical and fundamental research to capture sharp market movements.',
      'Trade and invest with confidence using deep-dive macroeconomic reports and real-time data analytics.',
    ],
    cta: 'Explore Research',
    href: '/research/',
  },
  {
    num: 'II.',
    title: 'A Relationship-Led Human Experience',
    sub: 'Premium investing experience with dedicated relationship management',
    points: [
      'Get mapped with experienced domain experts who understand your risk appetite and financial milestones.',
      'Experience seamless, personalized portfolio reviews over a call or in person, moving past automated chatbots.',
    ],
    cta: 'Meet Your Advisor',
    href: '/about/',
  },
  {
    num: 'III.',
    title: 'Partner Network',
    sub: 'Access to a dense nationwide network of trusted partners',
    points: [
      'Leverage trusted collaborations with leading financial institutions, asset managers, and tech platforms.',
      'Gain premium access to structured products, unique PMS strategies, and highly curated investment avenues.',
    ],
    cta: 'Our Story',
    href: '/about/',
  },
  {
    num: 'IV.',
    title: 'Personalized Notifications',
    sub: 'Personalized nudges for critical actionables and market opportunities',
    points: [
      'Receive instant, actionable alerts tailored to your active watchlist, technical breakouts, and entry/exit zones.',
      'Stay updated with automated, relevant news and rebalancing alerts without information overload.',
    ],
    cta: 'Explore Antara',
    href: '/about/antara-web-login/',
  },
];

const advisoryCards = [
  {
    icon: `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 24l6-6 5 5 7-9 6-4"/><path d="M28 4v6h-6"/></svg>`,
    title: 'Expert Research Calls',
    body: 'Daily SEBI-registered market research and insights.',
    cta: 'Start Learning',
    href: '/research/',
  },
  {
    icon: `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4,20 12,12 18,18 28,6"/><polyline points="22,6 28,6 28,12"/></svg>`,
    title: 'Trade Indian Equities',
    body: 'Access & execute seamless trades across the NSE and BSE.',
    cta: 'Explore Market',
    href: '/products/equity/',
  },
  {
    icon: `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="16" cy="12" r="5"/><path d="M8 28c0-4.4 3.6-8 8-8s8 3.6 8 8"/><path d="M24 8l4-4M28 12l-4-4"/></svg>`,
    title: "Today's Trading Ideas",
    body: 'Learn proven techniques from seasoned traders.',
    cta: 'Discover Trading Ideas',
    href: '/research/technical/',
  },
  {
    icon: `<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="16" cy="10" r="6"/><path d="M4 28c0-6.627 5.373-12 12-12s12 5.373 12 12"/></svg>`,
    title: 'Get Expert Advice',
    body: 'Stay aware and informed with real-time market analysis.',
    cta: 'Connect With An Advisor',
    href: '/about/support/',
  },
];

const allProducts = [
  {
    label: 'Equities',
    href: '/products/equity/',
    sub: 'Trade in NSE & BSE Equity with zero delay and in-depth research support.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polyline points="3,17 8,11 12,15 19,7"/><polyline points="15,7 19,7 19,11"/></svg>`,
  },
  {
    label: 'Margin Trading Facility (MTF)',
    href: '/products/mtf/',
    sub: 'Trade with leverage and increase your buying power with flexible margin options.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><ellipse cx="12" cy="7" rx="7" ry="2.5"/><path d="M5 7v5c0 1.4 3.1 2.5 7 2.5S19 13.4 19 12V7"/><path d="M5 12v3c0 1.4 3.1 2.5 7 2.5"/></svg>`,
  },
  {
    label: 'Derivatives',
    href: '/products/derivative/',
    sub: 'Trade Futures & Options to hedge your portfolio or maximise returns.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M7 17V7m0 0L4 10m3-3 3 3M17 7v10m0 0 3-3m-3 3-3-3"/></svg>`,
  },
  {
    label: 'Mutual Funds',
    href: '/products/mutual-funds/',
    sub: 'Compare 3,000+ Funds across categories and invest in direct plans at zero commission.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 3a9 9 0 0 1 9 9H12V3z"/><circle cx="12" cy="12" r="9"/></svg>`,
  },
  {
    label: 'Loan Against Mutual Funds (LAMF)',
    href: '/products/mtf/',
    sub: 'Get instant loans against your mutual fund holdings at competitive interest rates.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 2 21 7v8l-9 5-9-5V7z"/><path d="M9 12l2 2 4-4"/></svg>`,
  },
  {
    label: 'Initial Public Offering (IPO)',
    href: '/products/ipo/',
    sub: 'Apply for upcoming IPOs seamlessly. Explore SME & Mainboard news.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M4.5 17.5c-1.5 1.2-1.5 4-1.5 4s2.8-.3 4-1.5a1.8 1.8 0 0 0-2.5-2.5z"/><path d="M12 15.5 10 13A19 19 0 0 1 11.5 10 11 11 0 0 1 20 3c0 2-.5 6.5-5.5 10a19 19 0 0 1-2.5 2.5z"/></svg>`,
  },
  {
    label: 'Exchange Traded Funds (ETF)',
    href: '/products/etf/',
    sub: 'Diversify your portfolio with ETFs tracking indices, sectors, and commodities.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>`,
  },
  {
    label: 'National Pension Scheme (NPS)',
    href: '/products/nps/',
    sub: 'Tailored strategies for high net-worth investors by SEBI registered experts.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M20 12A8 8 0 1 0 4 12h16Z"/><path d="M15 16a3 3 0 0 1-6 0v-4"/></svg>`,
  },
];

const startSteps = [
  {
    title: 'Basic Information',
    desc: 'Name, mobile number, PAN — takes under two minutes.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>`,
  },
  {
    title: 'Complete eKYC via Aadhaar',
    desc: 'OTP-based verification — no physical forms or branch visits.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M9 7h6M9 11h6M9 15h4"/></svg>`,
  },
  {
    title: 'Upload Documents',
    desc: "Bank proof and a live photograph from your phone's camera.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>`,
  },
  {
    title: 'Digital eSign',
    desc: 'Aadhaar-based e-sign replaces physical signature on all forms.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>`,
  },
  {
    title: 'Account Activation',
    desc: 'Credentials delivered to your registered email. Start investing.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>`,
  },
];

const faqs = [
  {
    q: 'What is a Demat Account?',
    a: 'A Demat (Dematerialised) account holds your shares, bonds, mutual funds, and ETFs in electronic form — eliminating physical certificates. It is mandatory for trading on Indian stock exchanges (NSE and BSE). With Shriram, opening a Demat account is 100% digital and takes under 10 minutes.',
  },
  {
    q: 'What are the benefits of a Demat Account?',
    a: 'A Demat account eliminates risks associated with physical certificates (theft, forgery, damage). You get instant transfer of securities, easy monitoring of all holdings in one place, automatic credit of bonuses and splits, and seamless participation in IPOs, buybacks, and rights issues.',
  },
  {
    q: 'What are the brokerage charges for options trading with Shriram Securities?',
    a: 'Brokerage charges for options trading are structured to be competitive and straightforward. Shriram Securities charges a flat fee of ₹20 per executed order for options trading. To further understand and calculate the total costs, including brokerage, taxes, and other fees, you can use the Brokerage Calculator. This tool helps you estimate the net profit or loss on your trades by accounting for all applicable charges.',
  },
  {
    q: 'Are there any charges associated with the Demat Account?',
    a: 'Account opening and Annual Maintenance Charges (AMC) are ₹0 for both Trading and Demat Accounts. Standard SEBI and exchange-mandated statutory charges (STT, exchange transaction charges, GST, SEBI fees) apply to all trades as per regulations.',
  },
  {
    q: 'What is Intraday brokerage and Option brokerage?',
    a: 'Intraday equity trades are charged at a flat ₹20 per executed order. Options trades are also charged at a flat ₹20 per executed order, regardless of the premium value or lot size. Equity delivery is ₹0 — no brokerage.',
  },
  {
    q: 'Can I have multiple Demat Accounts?',
    a: 'Yes, SEBI permits investors to hold multiple Demat accounts across different depository participants (DPs). However, each account has its own AMC and charges. With Shriram, your Demat account is linked to your Trading account on the Antara platform for seamless management.',
  },
  {
    q: 'Is a Demat Account mandatory for applying for an IPO?',
    a: 'Yes. SEBI mandates that all IPO applications — whether through UPI ASBA or net banking — require a valid Demat account for share allotment. If allotted, shares are credited directly to your Demat account within T+6 days of the IPO closing date.',
  },
];
---

<BaseLayout title="" description="Shriram Financial Services — Advisory-Led Wealth Curation. Invest across equity, mutual funds, bonds and more with India's most trusted platform.">

  <!-- ══ HERO ══ -->
  <section class="relative xl:min-h-[calc(100vh-88px)] overflow-hidden">
    <div class="hero-wave" aria-hidden="true"></div>
    <video id="hero-video"
      class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-1000"
      autoplay muted playsinline aria-hidden="true">
      <source src="/9150545-hd_1920_1080_24fps.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-r from-white/82 via-white/48 to-white/0" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-black/8 via-transparent to-black/12" aria-hidden="true"></div>

    <div class="site-wrap relative z-10 flex items-start gap-8 py-14 sm:py-20 lg:py-24 xl:min-h-[calc(100vh-88px)] xl:items-center xl:gap-12 xl:py-0">

      <!-- Left text -->
      <div class="w-full xl:max-w-[560px] xl:shrink-0 reveal reveal-1">
        <h1 class="text-[28px] font-normal leading-[1.30] text-[var(--color-n900)] sm:text-[36px] lg:text-[54px]" style="font-family:var(--font-display)">
          Beyond Portfolios;<br>
          <span class="font-bold text-[var(--color-brand)]">Advisory-Led</span> Wealth Curation
        </h1>
        <p class="mt-5 text-[15px] leading-relaxed text-[var(--color-n800)] lg:text-[17px]">
          Don't just trade; grow your wealth with India's most trusted advisors.
        </p>

        <!-- Trust badges -->
        <div class="mt-5 flex flex-wrap items-center gap-x-3 gap-y-1.5">
          {['Trusted By 10L+ Investors', 'In-House Analyst Team', 'Pan-India Presence'].map((t, i) => (
            <div class="flex items-center gap-3">
              {i > 0 && <span class="trust-dot"></span>}
              <span class="text-[13px] font-medium text-[var(--color-n800)]">{t}</span>
            </div>
          ))}
        </div>

        <div class="mt-8">
          <a href="/about/antara-web-login/" class="btn-primary">Explore Antara</a>
        </div>
      </div>

      <!-- Right: glassmorphism Open Demat card -->
      <div class="reveal reveal-2 hidden flex-1 justify-end xl:flex">
        <div class="glass-form w-full max-w-[480px] rounded-xl p-10">
          <h2 class="text-[28px] font-semibold text-[var(--color-n900)]" style="font-family:var(--font-display)">
            Open a Demat Account
          </h2>
          <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1.5">
            {['100% Paperless', 'Open Within Minutes', 'SEBI Regulated'].map((t, i) => (
              <div class="flex items-center gap-3">
                {i > 0 && <span class="trust-dot" style="background:#aaa"></span>}
                <span class="text-[12px] text-[var(--color-n700)]">{t}</span>
              </div>
            ))}
          </div>
          <div class="mt-8">
            <div class="flex h-[52px] items-center gap-3 rounded-lg border border-[var(--color-n500)] bg-white px-4 shadow-sm">
              <span class="text-[20px]">🇮🇳</span>
              <span class="h-5 w-px bg-[var(--color-n400)]"></span>
              <div class="flex flex-col justify-center">
                <span class="text-[10px] font-semibold uppercase tracking-wide text-[var(--color-n700)]">Mobile Number</span>
                <span class="text-[13px] font-medium text-[var(--color-n800)]">+91</span>
              </div>
              <input
                type="tel"
                placeholder="Enter mobile number"
                class="flex-1 border-none bg-transparent text-[15px] font-medium text-[var(--color-ink)] outline-none placeholder:text-[var(--color-n500)]"
              />
            </div>
            <p class="mt-2.5 text-[11px] text-[var(--color-n700)]">
              By continuing, I agree to receive the OTP and updates via SMS/WhatsApp.
            </p>
          </div>
          <div class="mt-6 space-y-3">
            <a href="/about/open-demat-account/" class="btn-primary w-full justify-center text-[15px]">
              Get Started
            </a>
            <p class="text-center text-[13px] text-[var(--color-n700)]">
              Already a part of us?{' '}
              <a href="/about/antara-web-login/" class="font-medium text-[var(--color-link)] hover:underline">Login Here.</a>
            </p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ══ HOW ARE WE DIFFERENT? ══ -->
  <section class="bg-[var(--color-dark-800)] relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 opacity-[0.04]"
         style="background-image:repeating-linear-gradient(-45deg,#fff 0,#fff 1px,transparent 0,transparent 50%);background-size:24px 24px;"></div>
    <div class="site-wrap relative py-16 lg:py-20">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-20">
        <div class="self-start lg:sticky lg:top-28">
          <h2 class="text-[28px] font-bold leading-tight text-white sm:text-[34px] lg:text-[48px]" style="font-family:var(--font-display)">
            How Are We <span class="text-[var(--color-brand-light)]">Different?</span>
          </h2>
          <p class="mt-5 text-[15px] leading-relaxed text-[rgba(255,255,255,0.60)]">
            We go beyond execution-only; by fusing together Historical Insights, Human Engagement and Tech that delivers better investing experiences to build long term customer relationships.
          </p>
        </div>
        <div class="space-y-0" id="differ-accord">
          {differItems.map((item, i) => (
            <details class="accord-item group" open={i === 0}>
              <summary class="flex cursor-pointer select-none items-start justify-between gap-4 px-6 py-7">
                <div class="flex-1">
                  <div class="flex items-baseline gap-3">
                    <span class="text-[13px] font-bold text-[rgba(255,255,255,0.35)]">{item.num}</span>
                    <h3 class="text-[19px] font-semibold text-white" style="font-family:var(--font-display)">{item.title}</h3>
                  </div>
                  <p class="mt-1 pl-7 text-[13px] text-[rgba(255,255,255,0.45)]">{item.sub}</p>
                </div>
                <span class="mt-1 shrink-0 text-[rgba(255,255,255,0.40)] transition-transform group-open:rotate-90">
                  <svg viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4"><path d="M6 4l4 4-4 4V4z"/></svg>
                </span>
              </summary>
              <div class="px-6 pb-7">
                <ul class="space-y-2.5 pl-7">
                  {item.points.map(p => (
                    <li class="flex items-start gap-2.5 text-[14px] text-[rgba(255,255,255,0.65)]">
                      <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-gold)]"></span>
                      {p}
                    </li>
                  ))}
                </ul>
                <a href={item.href} class="mt-6 inline-flex items-center gap-2 rounded border border-[rgba(255,255,255,0.25)] px-5 py-2.5 text-[13px] font-medium text-white transition-colors hover:border-white hover:bg-white/10 ml-7">
                  {item.cta}
                  <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" class="h-3 w-3"><path d="M2 6h8M6 2l4 4-4 4"/></svg>
                </a>
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ STRATEGIC ADVISORY ══ -->
  <section class="bg-white">
    <div class="site-wrap py-16 lg:py-20">
      <h2 class="text-[22px] font-bold text-[var(--color-n900)] sm:text-[28px] lg:text-[42px]" style="font-family:var(--font-display)">
        Strategic Advisory For <span class="text-[var(--color-brand)]">Every Investor</span>
      </h2>
      <p class="mt-4 max-w-4xl text-[15px] text-[var(--color-muted)]">
        From initial concepts to managed portfolios, our personal managers collaborate with you to ensure every transaction is backed by professional insight.
      </p>

      <div class="advisory-grid mt-10 grid gap-0 sm:grid-cols-2 lg:grid-cols-4 border border-[var(--color-n400)] rounded-[4px] overflow-hidden">
        {advisoryCards.map((c, i) => (
          <div class={`advisory-card group relative flex min-h-[322px] flex-col overflow-hidden bg-white px-6 py-10 ${i < 3 ? 'lg:border-r border-[var(--color-n400)]' : ''} ${i < 2 ? 'sm:border-b lg:border-b-0 border-[var(--color-n400)]' : ''}`}>
            <span set:html={c.icon} class="h-[52px] w-[52px] shrink-0 block text-[var(--color-brand)]"/>
            <div class="mt-8 flex flex-col gap-4">
              <h3 class="text-[16px] font-bold uppercase tracking-[1.2px] text-[var(--color-n900)]">{c.title}</h3>
              <p class="text-[14px] leading-[1.5] text-[var(--color-n800)]">{c.body}</p>
            </div>
            <a href={c.href}
               class="absolute bottom-[-56px] left-0 flex h-14 w-full items-center justify-center gap-3 bg-[var(--color-brand)] text-[14px] font-medium text-white transition-all duration-300 group-hover:bottom-0">
              {c.cta}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 shrink-0"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        ))}
      </div>

      <!-- Nudge CTA -->
      <div class="mt-6 flex flex-col items-start justify-between gap-5 overflow-hidden rounded-[4px] border border-[var(--color-n400)] bg-[var(--color-n100)] px-8 py-6 sm:flex-row sm:items-center">
        <div class="flex items-start gap-5">
          <div class="hidden h-16 w-16 shrink-0 items-center justify-center rounded-full bg-[var(--color-brand-pale)] sm:flex">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="h-8 w-8 text-[var(--color-brand)]"><circle cx="16" cy="10" r="6"/><path d="M4 28c0-6.627 5.373-12 12-12s12 5.373 12 12"/><path d="M22 20l3 3 5-5"/></svg>
          </div>
          <div>
            <p class="text-[16px] font-semibold text-[var(--color-n900)]">
              Unsure on where to begin? <span class="text-[var(--color-brand)]">We've got you.</span>
            </p>
            <p class="mt-1 text-[13px] leading-relaxed text-[var(--color-muted)]">
              Our dedicated specialists evaluate your initial concepts, followed by a personal manager who will collaborate with you to architect a comprehensive financial roadmap.
            </p>
          </div>
        </div>
        <a href="/about/support/" class="btn-primary shrink-0">Schedule a Call</a>
      </div>
    </div>
  </section>

  <!-- ══ PRODUCTS ══ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-900)]">
    <div class="pointer-events-none absolute inset-0 opacity-[0.03]"
         style="background-image:repeating-linear-gradient(-45deg,#fff 0,#fff 1px,transparent 0,transparent 50%);background-size:20px 20px;"></div>
    <div class="site-wrap relative py-16 lg:py-20">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2 class="text-[26px] font-bold leading-tight text-white sm:text-[32px] lg:text-[44px]" style="font-family:var(--font-display)">
            Trade, Invest Or Lend.<br class="hidden sm:block"> <span class="text-[#FFD600]">All At One Place.</span>
          </h2>
          <p class="mt-3 text-[15px] text-[rgba(255,255,255,0.55)]">
            From personalized insights to instant transactions, everything you need is now in one place.
          </p>
        </div>
        <a href="/products/" class="shrink-0 text-[13px] font-semibold text-[var(--color-brand-light)] hover:text-white">
          View All Our Products →
        </a>
      </div>
      <div class="mt-10 grid grid-cols-2 gap-4 lg:grid-cols-4">
        {allProducts.map(p => (
          <a href={p.href}
             class="group relative flex h-[284px] flex-col overflow-hidden rounded-[4px] border border-white/10 bg-[var(--color-dark-800)] p-7 transition-all duration-300 hover:z-10 hover:-translate-y-1 hover:scale-[1.04] hover:border-[var(--color-brand)] hover:bg-[var(--color-brand)]">
            <!-- Yellow arrow circle — scales in on hover -->
            <div class="absolute right-5 top-5 flex h-[52px] w-[52px] scale-0 items-center justify-center rounded-full bg-[#FFD600] transition-transform duration-300 ease-out group-hover:scale-100">
              <svg viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
