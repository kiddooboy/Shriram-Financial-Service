<script>
  /* Fade in hero video */
  const heroVideo = document.getElementById('hero-video') as HTMLVideoElement | null;
  const heroWave  = document.querySelector('.hero-wave') as HTMLElement | null;
  if (heroVideo) {
    const showVideo = () => {
      heroVideo.classList.remove('opacity-0');
      heroVideo.classList.add('opacity-100');
      if (heroWave) heroWave.style.opacity = '0';
    };
    if (heroVideo.readyState >= 3) showVideo();
    else heroVideo.addEventListener('canplaythrough', showVideo, { once: true });

    heroVideo.addEventListener('timeupdate', () => {
      if (heroVideo.duration && heroVideo.currentTime >= heroVideo.duration - 0.08) {
        heroVideo.currentTime = 0;
      }
    });
    heroVideo.addEventListener('ended', () => { heroVideo.currentTime = 0; heroVideo.play(); });
  }

  /* "How Are We Different?" — auto-scroll the card panel */
  const differScroll = document.getElementById('differ-scroll');
  if (differScroll) {
    let paused = false;
    let raf: number;
    const SPEED = 0.6; // px per frame

    const tick = () => {
      if (!paused) {
        differScroll.scrollTop += SPEED;
        // loop back to top when end reached
        if (differScroll.scrollTop + differScroll.clientHeight >= differScroll.scrollHeight - 2) {
          setTimeout(() => { differScroll.scrollTop = 0; }, 800);
        }
      }
      raf = requestAnimationFrame(tick);
    };

    differScroll.addEventListener('mouseenter', () => { paused = true; });
    differScroll.addEventListener('mouseleave', () => { paused = false; });
    differScroll.addEventListener('touchstart',  () => { paused = true;  }, { passive: true });
    differScroll.addEventListener('touchend',    () => { paused = false; }, { passive: true });

    raf = requestAnimationFrame(tick);
  }

  /* Product cards — inward scroll-reveal */
  const productCards = document.querySelectorAll<HTMLElement>('.product-card-reveal');
  if (productCards.length) {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add('revealed');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12 }
    );
    productCards.forEach(card => revealObserver.observe(card));
  }

  /* Accordion — one open at a time */
  const accord = document.getElementById('differ-accord');
  accord?.querySelectorAll('details').forEach(d => {
    d.addEventListener('toggle', () => {
      if (d.open) {
        accord.querySelectorAll<HTMLDetailsElement>('details').forEach(other => {
          if (other !== d) other.removeAttribute('open');
        });
      }
    });
  });
</script>
