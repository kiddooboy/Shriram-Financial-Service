<script>
  /* Fade in hero video + seamless manual loop (avoids browser's native loop rebuffer gap) */
  const heroVideo = document.getElementById('hero-video') as HTMLVideoElement | null;
  const heroWave  = document.querySelector('.hero-wave') as HTMLElement | null;
  if (heroVideo) {
    const showVideo = () => {
      heroVideo.classList.remove('opacity-0');
      heroVideo.classList.add('opacity-100');
      if (heroWave) heroWave.style.opacity = '0';
    };
    if (heroVideo.readyState >= 3) showVideo();
    else heroVideo.addEventListener('canplaythrough', showVideo, { once: true });

    heroVideo.addEventListener('timeupdate', () => {
      if (heroVideo.duration && heroVideo.currentTime >= heroVideo.duration - 0.08) {
        heroVideo.currentTime = 0;
      }
    });

    heroVideo.addEventListener('ended', () => {
      heroVideo.currentTime = 0;
      heroVideo.play();
    });
  }

  /* Cycling goal text — Groww-style float-up animation */
  const goals = ['Retirement', 'Children', 'Home Purchase', 'Tax Savings', 'Wealth Building', 'Your Family'];
  let gi = 0;
  const gt = document.getElementById('goal-text') as HTMLElement | null;
  if (gt) {
    gt.style.display = 'inline-block';
    gt.style.opacity = '1';
    gt.style.transform = 'translateY(0)';

    const cycle = () => {
      // Float current word up and fade out
      gt.style.transition = 'opacity 0.35s ease, transform 0.35s ease';
      gt.style.opacity = '0';
      gt.style.transform = 'translateY(-20px)';

      setTimeout(() => {
        // Swap word and snap to below (invisible)
        gi = (gi + 1) % goals.length;
        gt.textContent = goals[gi];
        gt.style.transition = 'none';
        gt.style.opacity = '0';
        gt.style.transform = 'translateY(20px)';

        // Trigger reflow so the snap registers before animating in
        void gt.offsetHeight;

        // Float new word up into place and fade in
        gt.style.transition = 'opacity 0.45s ease, transform 0.45s ease';
        gt.style.opacity = '1';
        gt.style.transform = 'translateY(0)';
      }, 380);
    };

    setInterval(cycle, 3200);
  }

  /* Accordion — one open at a time */
  const accord = document.getElementById('differ-accord');
  accord?.querySelectorAll('details').forEach(d => {
    d.addEventListener('toggle', () => {
      if (d.open) {
        accord.querySelectorAll<HTMLDetailsElement>('details').forEach(other => {
          if (other !== d) other.removeAttribute('open');
        });
      }
    });
  });
</script>
