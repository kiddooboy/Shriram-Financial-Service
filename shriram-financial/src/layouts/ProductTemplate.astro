---
import BaseLayout from './BaseLayout.astro';

interface Feature { title: string; body: string; }
interface Faq { q: string; a: string; }

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  tagline: string;
  intro: string;
  features?: Feature[];
  faqs?: Faq[];
}

const {
  title, description, eyebrow = 'Products', tagline, intro,
  features = [], faqs = [],
} = Astro.props;
---

<BaseLayout title={title} description={description}>

  <!-- ── Hero ── -->
  <section class="bg-[var(--color-dark-800)] relative overflow-hidden">
    <div class="pointer-events-none absolute -right-32 -top-32 h-96 w-96 rounded-full bg-[var(--color-brand)]/20 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 -left-16 h-64 w-64 rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>

    <div class="site-wrap relative py-14 sm:py-20 lg:py-28">
      <p class="reveal reveal-1 text-[11px] font-bold uppercase tracking-widest text-[rgba(255,255,255,0.40)]">{eyebrow}</p>
      <h1 class="reveal reveal-2 mt-4 max-w-3xl text-[26px] font-bold leading-tight text-white sm:text-[34px] lg:text-[54px]" style="font-family:var(--font-display)">{title}</h1>
      <p class="reveal reveal-3 mt-5 max-w-2xl text-[15px] leading-relaxed text-[rgba(255,255,255,0.65)] lg:text-[16px]">{tagline}</p>
      <div class="reveal reveal-4 mt-8 flex flex-wrap gap-3">
        <a href="/about/open-demat-account/" class="btn-primary">Open Demat Account</a>
        <a href="/product-hub/" class="inline-flex h-12 items-center gap-2 rounded border border-white/25 px-6 text-[14px] font-medium text-white transition-colors hover:bg-white/10">
          Try Calculators
        </a>
      </div>
    </div>
  </section>

  <!-- ── Intro ── -->
  <section class="site-wrap py-14 lg:py-20">
    <p class="max-w-4xl text-[17px] leading-[1.7] text-[var(--color-n900)] sm:text-[20px] lg:text-[24px]" style="font-family:var(--font-display)">
      {intro}
    </p>
  </section>

  <!-- ── Features ── -->
  {features.length > 0 && (
    <section class="site-wrap pb-14">
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <article class="product-card-light p-7">
            <h3 class="text-[18px] font-semibold text-[var(--color-n900)]" style="font-family:var(--font-display)">{f.title}</h3>
            <p class="mt-3 text-[14px] leading-relaxed text-[var(--color-muted)]">{f.body}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  <!-- Slot for extra content -->
  <slot />

  <!-- ── FAQs ── -->
  {faqs.length > 0 && (
    <section class="mx-auto max-w-3xl px-6 py-16 lg:px-8 lg:py-20">
      <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">FAQ</p>
      <h2 class="mt-3 text-[28px] font-bold text-[var(--color-n900)] lg:text-[32px]" style="font-family:var(--font-display)">Frequently Asked Questions</h2>
      <div class="mt-8 divide-y divide-[var(--color-n400)] overflow-hidden rounded-[24px] border border-[var(--color-n400)]">
        {faqs.map((item, i) => (
          <details class="faq-row group">
            <summary class="flex items-center justify-between gap-4 px-6 py-5">
              <span class="text-[15px] font-medium text-[var(--color-n900)]">{item.q}</span>
              <span class="grid h-6 w-6 shrink-0 place-items-center rounded-full border border-[var(--color-n400)] text-[var(--color-n700)] transition-transform group-open:rotate-45">
                <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" class="h-3 w-3"><path d="M6 2v8M2 6h8"/></svg>
              </span>
            </summary>
            <div class="border-t border-[var(--color-n400)] bg-[var(--color-n100)] px-6 py-5">
              <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </section>
  )}

  <!-- ── CTA band ── -->
  <section class="site-wrap pb-16">
    <div class="relative overflow-hidden rounded-[24px] bg-[var(--color-brand)] p-10 lg:p-14">
      <div class="pointer-events-none absolute right-0 top-0 h-64 w-64 translate-x-16 -translate-y-16 rounded-full bg-white/10 blur-2xl"></div>
      <div class="relative flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
        <div>
          <h2 class="text-[28px] font-bold text-[#202318] lg:text-[32px]" style="font-family:var(--font-display)">Start Investing Today</h2>
          <p class="mt-2 max-w-md text-[14px] text-[#202318]/70">Open a free Demat account in under 10 minutes — zero delivery brokerage, SEBI-registered research, and a dedicated advisor.</p>
        </div>
        <div class="flex shrink-0 flex-wrap gap-3">
          <a href="/about/open-demat-account/" class="inline-flex h-12 items-center rounded bg-[#202318] px-7 text-[14px] font-semibold text-white transition-all hover:-translate-y-0.5 hover:bg-black">Open Demat Account</a>
          <a href="/product-hub/" class="inline-flex h-12 items-center rounded border border-[#202318]/30 px-7 text-[14px] font-medium text-[#202318] transition-all hover:bg-[#202318]/10">Calculators</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
