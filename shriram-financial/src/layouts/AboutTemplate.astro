---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  lead: string;
}
const { title, description, eyebrow = 'About Us', lead } = Astro.props;
---

<BaseLayout title={title} description={description}>

  <!-- Header band -->
  <section class="border-b border-[var(--color-n400)] bg-[var(--color-n100)]">
    <div class="site-wrap py-12 sm:py-16 lg:py-20">
      <p class="reveal reveal-1 text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">{eyebrow}</p>
      <h1 class="reveal reveal-2 mt-4 text-[26px] font-bold text-[var(--color-n900)] sm:text-[34px] lg:text-[52px]" style="font-family:var(--font-display)">{title}</h1>
      <p class="reveal reveal-3 mt-5 max-w-2xl text-[15px] leading-relaxed text-[var(--color-muted)] lg:text-[16px]">{lead}</p>
    </div>
  </section>

  <!-- Content -->
  <section class="site-wrap py-14 lg:py-20">
    <div class="prose-shriram">
      <slot />
    </div>
  </section>

  <!-- CTA band -->
  <section class="site-wrap pb-16">
    <div class="relative overflow-hidden rounded-[24px] bg-[var(--color-brand)] p-10 lg:p-12">
      <div class="pointer-events-none absolute right-0 top-0 h-64 w-64 translate-x-16 -translate-y-16 rounded-full bg-white/10 blur-2xl"></div>
      <div class="relative flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
        <div>
          <h2 class="text-[26px] font-bold text-[#202318] lg:text-[30px]" style="font-family:var(--font-display)">Ready to Start Investing?</h2>
          <p class="mt-2 max-w-md text-[14px] text-[#202318]/75">Open a free Demat account in under 10 minutes — zero delivery brokerage, SEBI-registered research, dedicated advisor.</p>
        </div>
        <div class="flex shrink-0 flex-wrap gap-3">
          <a href="/about/open-demat-account/" class="inline-flex h-12 items-center rounded bg-[#202318] px-7 text-[14px] font-semibold text-white transition-all hover:-translate-y-0.5 hover:bg-black">Open Free Demat Account</a>
          <a href="/about/support/" class="inline-flex h-12 items-center rounded border border-[#202318]/30 px-7 text-[14px] font-medium text-[#202318] transition-all hover:bg-[#202318]/10">Talk to an Advisor</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
