---
import { navigation } from '../navigation';
const currentPath = Astro.url.pathname;
const products = navigation.find(n => n.label === 'Products')!;
const research  = navigation.find(n => n.label === 'Research')!;
const about     = navigation.find(n => n.label === 'About')!;
---

<header id="site-header" class="sticky top-0 z-50 h-[80px] border-b border-[#f2f2f2] bg-[rgba(255,255,255,0.80)] backdrop-blur-[30px]">
  <div class="site-wrap flex h-full items-center justify-between">

    <!-- Logo -->
    <div class="flex shrink-0 items-center gap-10">
      <a href="/" class="flex shrink-0 items-center rounded-[4px] bg-white py-[4px]" aria-label="Shriram Financial Services">
        <img src="/shriram-logo.png" alt="Shriram Financial Services" width="114" height="48"
             class="h-[48px] w-auto object-contain"
             style="image-rendering:auto;" />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden items-center gap-6 lg:flex" aria-label="Primary">

        <!-- Products mega -->
        <div class="group relative">
          <button class="flex items-center gap-1 rounded-[10px] px-3 py-1 text-[14px] font-medium text-[#333] transition-colors hover:bg-[var(--color-n100)]" aria-haspopup="true">
            Products
            <svg class="h-3.5 w-3.5 opacity-50 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 16 16" fill="currentColor"><path d="M4 6l4 4 4-4H4z"/></svg>
          </button>
          <div class="invisible absolute left-0 top-full z-50 pt-3 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100">
            <div class="w-[720px] overflow-hidden rounded-lg border border-[var(--color-n400)] bg-white shadow-[var(--shadow-heavy)]">
              <div class="grid grid-cols-3 gap-0 border-b border-[var(--color-n100)] bg-[var(--color-n100)] px-6 py-3">
                <span class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-subtle)]">Trade</span>
                <span class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-subtle)]">Invest</span>
                <span class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-subtle)]">More</span>
              </div>
              <div class="grid grid-cols-3 gap-0 p-2">
                <div class="flex flex-col gap-0.5">
                  {[
                    {label:'Equity', href:'/products/equity/'},
                    {label:'Derivative', href:'/products/derivative/'},
                    {label:'Commodities', href:'/products/commodities/'},
                    {label:'MTF', href:'/products/mtf/'},
                    {label:'Currency', href:'/products/currency/'},
                  ].map(p => (
                    <a href={p.href} class="rounded px-4 py-2.5 text-[13px] text-[var(--color-ink)] hover:bg-[var(--color-brand-pale)] hover:text-[var(--color-brand)]">{p.label}</a>
                  ))}
                </div>
                <div class="flex flex-col gap-0.5 border-x border-[var(--color-n100)]">
                  {[
                    {label:'Mutual Funds', href:'/products/mutual-funds/'},
                    {label:'ETF', href:'/products/etf/'},
                    {label:'Bonds', href:'/products/bonds/'},
                    {label:'NPS', href:'/products/nps/'},
                    {label:'NFO', href:'/products/nfo/'},
                    {label:'IPO', href:'/products/ipo/'},
                  ].map(p => (
                    <a href={p.href} class="rounded px-4 py-2.5 text-[13px] text-[var(--color-ink)] hover:bg-[var(--color-brand-pale)] hover:text-[var(--color-brand)]">{p.label}</a>
                  ))}
                </div>
                <div class="flex flex-col gap-0.5">
                  {[
                    {label:'FD', href:'/products/fd/'},
                    {label:'Global Investing', href:'/products/global-investing/'},
                  ].map(p => (
                    <a href={p.href} class="rounded px-4 py-2.5 text-[13px] text-[var(--color-ink)] hover:bg-[var(--color-brand-pale)] hover:text-[var(--color-brand)]">{p.label}</a>
                  ))}
                </div>
              </div>
              <div class="flex items-center justify-between border-t border-[var(--color-n100)] bg-[var(--color-brand-pale)] px-6 py-3">
                <span class="text-[12px] text-[var(--color-subtle)]">13 investment products across trade, invest & more</span>
                <a href="/products/" class="text-[12px] font-semibold text-[var(--color-brand)] hover:underline">View all products →</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Learning Centre -->
        <div class="group relative">
          <button class="flex items-center gap-1 rounded-[10px] px-3 py-1 text-[14px] font-medium text-[#333] transition-colors hover:bg-[var(--color-n100)]" aria-haspopup="true">
            Learning Centre
            <svg class="h-3.5 w-3.5 opacity-50 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 16 16" fill="currentColor"><path d="M4 6l4 4 4-4H4z"/></svg>
          </button>
          <div class="invisible absolute left-0 top-full z-50 pt-3 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100">
            <div class="w-52 overflow-hidden rounded-lg border border-[var(--color-n400)] bg-white py-1 shadow-[var(--shadow-heavy)]">
              {[
                {label:'Research & Insights', href:'/research/'},
                {label:'Technical Analysis',  href:'/research/technical/'},
                {label:'Market News',          href:'/research/'},
              ].map(c => (
                <a href={c.href} class="block px-4 py-2.5 text-[13px] text-[var(--color-ink)] hover:bg-[var(--color-n100)]">{c.label}</a>
              ))}
            </div>
          </div>
        </div>

        <!-- Calculators -->
        <div class="group relative">
          <button class="flex items-center gap-1 rounded-[10px] px-3 py-1 text-[14px] font-medium text-[#333] transition-colors hover:bg-[var(--color-n100)]" aria-haspopup="true">
            Calculators
            <svg class="h-3.5 w-3.5 opacity-50 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 16 16" fill="currentColor"><path d="M4 6l4 4 4-4H4z"/></svg>
          </button>
          <div class="invisible absolute left-0 top-full z-50 pt-3 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100">
            <div class="w-52 overflow-hidden rounded-lg border border-[var(--color-n400)] bg-white py-1 shadow-[var(--shadow-heavy)]">
              {[
                {label:'SIP Calculator',      href:'/product-hub/'},
                {label:'Returns Calculator',  href:'/product-hub/'},
                {label:'EMI Calculator',      href:'/product-hub/'},
              ].map(c => (
                <a href={c.href} class="block px-4 py-2.5 text-[13px] text-[var(--color-ink)] hover:bg-[var(--color-n100)]">{c.label}</a>
              ))}
            </div>
          </div>
        </div>

        <!-- Support -->
        <div class="group relative">
          <button class="flex items-center gap-1 rounded-[10px] px-3 py-1 text-[14px] font-medium text-[#333] transition-colors hover:bg-[var(--color-n100)]" aria-haspopup="true">
            Support
            <svg class="h-3.5 w-3.5 opacity-50 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 16 16" fill="currentColor"><path d="M4 6l4 4 4-4H4z"/></svg>
          </button>
          <div class="invisible absolute left-0 top-full z-50 pt-3 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100">
            <div class="w-52 overflow-hidden rounded-lg border border-[var(--color-n400)] bg-white py-1 shadow-[var(--shadow-heavy)]">
              {[
                {label:'Contact & Help',          href:'/about/support/'},
                {label:'Grievance Redressal',     href:'/about/support/'},
                {label:'Regulatory & Compliance', href:'/about/regulatory/'},
              ].map(c => (
                <a href={c.href} class="block px-4 py-2.5 text-[13px] text-[var(--color-ink)] hover:bg-[var(--color-n100)]">{c.label}</a>
              ))}
            </div>
          </div>
        </div>

        <!-- Become a Partner -->
        <a href="/about/become-a-partner/" class="rounded-[10px] px-3 py-1 text-[14px] font-medium text-[#333] transition-colors hover:bg-[var(--color-n100)]">Become a Partner</a>
      </nav>
    </div>

    <!-- Right: Search + Auth -->
    <div class="flex items-center gap-16">

      <!-- Search bar with rolling ticker -->
      <div class="hidden h-[40px] w-[246px] items-center justify-between rounded-[4px] border border-[#f2f2f2] bg-white px-3 lg:flex">
        <div class="relative h-[16px] flex-1 overflow-hidden">
          <span class="absolute left-0 top-0 text-[12px] font-medium leading-[16px] text-[#333]">Search for</span>
          <div class="search-ticker">
            <span class="search-ticker-item">Stocks</span>
            <span class="search-ticker-item">Loans</span>
            <span class="search-ticker-item">Investment Ideas</span>
            <span class="search-ticker-item">Questions</span>
            <span class="search-ticker-item">Funds</span>
            <span class="search-ticker-item">Bonds</span>
            <span class="search-ticker-item">Mutual Funds</span>
            <span class="search-ticker-item">Stocks</span>
          </div>
        </div>
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" class="h-5 w-5 shrink-0 text-[#333]"><circle cx="8.5" cy="8.5" r="5.5"/><path stroke-linecap="round" d="M15.5 15.5l-2.5-2.5"/></svg>
      </div>

      <!-- Login + CTA -->
      <div class="flex items-center gap-4">
        <!-- Login -->
        <div class="group relative hidden lg:block">
          <button class="flex items-center gap-1 text-[14px] font-medium text-[#2f7ef4] transition-opacity hover:opacity-80">
            Login
            <svg class="h-3.5 w-3.5 opacity-70 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 16 16" fill="currentColor"><path d="M4 6l4 4 4-4H4z"/></svg>
          </button>
          <div class="invisible absolute right-0 top-full z-50 pt-2 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100">
            <div class="w-44 overflow-hidden rounded-lg border border-[var(--color-n400)] bg-white py-1 shadow-[var(--shadow-heavy)]">
              <a href="/about/antara-web-login/" class="block px-4 py-2.5 text-[13px] text-[var(--color-ink)] hover:bg-[var(--color-n100)]">Antara Web Login</a>
              <a href="/about/antara-web-login/" class="block px-4 py-2.5 text-[13px] text-[var(--color-ink)] hover:bg-[var(--color-n100)]">Back Office</a>
            </div>
          </div>
        </div>

        <!-- Open A Trading Account CTA -->
        <a href="/about/open-demat-account/" class="hidden h-[40px] items-center justify-center rounded-[4px] bg-[#333] px-5 text-[12px] font-medium text-white transition-colors hover:bg-[#111] lg:flex">
          Open A Trading Account
        </a>

        <!-- Mobile hamburger -->
        <button id="menu-toggle" class="flex h-9 w-9 items-center justify-center rounded border border-[var(--color-n400)] text-[var(--color-ink)] lg:hidden" aria-label="Open menu" aria-expanded="false">
          <svg id="icon-open" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg id="icon-close" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div id="mobile-menu" class="hidden border-t border-[var(--color-n400)] bg-white lg:hidden">
    <div class="max-h-[80vh] overflow-y-auto px-5 py-4">
      <details class="group mb-1">
        <summary class="flex cursor-pointer select-none items-center justify-between rounded px-3 py-3 text-[14px] font-semibold text-[var(--color-ink)] hover:bg-[var(--color-n100)]">
          Products
          <svg class="h-4 w-4 opacity-50 transition-transform group-open:rotate-180" viewBox="0 0 16 16" fill="currentColor"><path d="M4 6l4 4 4-4H4z"/></svg>
        </summary>
        <div class="ml-3 mt-1 grid grid-cols-2 gap-1 border-l-2 border-[var(--color-n400)] pl-3 pb-2">
          {products.children.map(p => (
            <a href={p.href} class="rounded px-3 py-2 text-[13px] text-[var(--color-muted)] hover:text-[var(--color-brand)]">{p.label}</a>
          ))}
        </div>
      </details>
      <a href="/research/" class="block rounded px-3 py-3 text-[14px] font-semibold text-[var(--color-ink)] hover:bg-[var(--color-n100)]">Learning Centre</a>
      <a href="/product-hub/" class="block rounded px-3 py-3 text-[14px] font-semibold text-[var(--color-ink)] hover:bg-[var(--color-n100)]">Calculators</a>
      <a href="/about/support/" class="block rounded px-3 py-3 text-[14px] font-semibold text-[var(--color-ink)] hover:bg-[var(--color-n100)]">Support</a>
      <a href="/about/become-a-partner/" class="block rounded px-3 py-3 text-[14px] font-semibold text-[var(--color-ink)] hover:bg-[var(--color-n100)]">Become a Partner</a>
      <details class="group mb-1">
        <summary class="flex cursor-pointer select-none items-center justify-between rounded px-3 py-3 text-[14px] font-semibold text-[var(--color-ink)] hover:bg-[var(--color-n100)]">
          About
          <svg class="h-4 w-4 opacity-50 transition-transform group-open:rotate-180" viewBox="0 0 16 16" fill="currentColor"><path d="M4 6l4 4 4-4H4z"/></svg>
        </summary>
        <div class="ml-3 mt-1 border-l-2 border-[var(--color-n400)] pl-3 pb-2">
          {about.children.map(c => (
            <a href={c.href} class="block rounded px-3 py-2 text-[13px] text-[var(--color-muted)] hover:text-[var(--color-brand)]">{c.label}</a>
          ))}
        </div>
      </details>
      <div class="mt-4 flex flex-col gap-3 border-t border-[var(--color-n400)] pt-4">
        <a href="/about/antara-web-login/" class="block rounded border border-[var(--color-n400)] py-3 text-center text-[13px] font-medium text-[var(--color-ink)]">Login</a>
        <a href="/about/open-demat-account/" class="block rounded bg-[#333] py-3 text-center text-[13px] font-medium text-white">Open A Trading Account</a>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle    = document.getElementById('menu-toggle')!;
  const menu      = document.getElementById('mobile-menu')!;
  const iconOpen  = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;
  toggle.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
